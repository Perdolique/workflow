{
  "name": "workflow",
  "version": "1.0.0",
  "description": "Useful tools and utilities",
  "scripts": {
    "lint:markdown": "markdownlint '**/*.md'",
    "lint:skills": "./scripts/lint-skills.sh",
    "setup:skills": "./scripts/setup-global-skills.sh",
    "update:skills": "vpx skills update --global",
    "update:all": "taze --include-locked --interactive",
    "prepare": "husky"
  },
  "keywords": [
    "tools",
    "utilities",
    "workflow",
    "skills",
    "agents"
  ],
  "author": "Perdolique",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.4.0",
  "devDependencies": {
    "husky": "9.1.7",
    "markdownlint": "0.40.0",
    "markdownlint-cli": "0.48.0",
    "taze": "19.14.1"
  }
}
