# This file is opt-in. Review every rule before installing it globally.

prefix_rule(pattern=["cd"], decision="allow")
prefix_rule(pattern=["gh", "api", "--method", "GET"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
prefix_rule(pattern=["git", "pull"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["npm", "run"], decision="allow")
prefix_rule(pattern=["npx", "-y", "modern-web-guidance@latest"], decision="allow")
prefix_rule(pattern=["pkill", "-f", "modern-web-guidance"], decision="allow")
prefix_rule(pattern=["pnpm", "add"], decision="allow")
prefix_rule(pattern=["pnpm", "dev"], decision="allow")
prefix_rule(pattern=["pnpm", "exec"], decision="allow")
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["pnpm", "remove"], decision="allow")
prefix_rule(pattern=["pnpm", "run"], decision="allow")
prefix_rule(pattern=["pnpm", "typecheck"], decision="allow")
prefix_rule(pattern=["pnpm", "view"], decision="allow")
prefix_rule(pattern=["pnpm", "why"], decision="allow")
prefix_rule(pattern=["vp", "run"], decision="allow")
